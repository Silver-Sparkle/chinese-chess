/* 对局页面 */
.game-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F5E6D3;
}

/* 顶部信息栏 */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #e0d5c0;
}

.player-info {
  display: flex;
  flex-direction: column;
}

.player-info.opponent {
  align-items: flex-start;
}

.player-info.self {
  align-items: flex-start;
}

.player-color {
  font-size: 30rpx;
  font-weight: 700;
}

.player-color.red {
  color: #c0392b;
}

.player-color.black {
  color: #2c3e50;
}

.player-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 2rpx;
}

.game-status {
  text-align: center;
}

.status-text {
  font-size: 28rpx;
  color: #8B4513;
  font-weight: 500;
}

/* 棋盘 */
.board-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx;
  min-height: 0;
}

.chess-canvas {
  width: 100%;
  height: 100%;
  max-width: 700rpx;
  max-height: 780rpx;
}

/* 底部栏 */
.bottom-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 30rpx;
  background: #fff;
  border-top: 1rpx solid #e0d5c0;
}

.action-buttons {
  display: flex;
  gap: 12rpx;
}

.btn-small {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  border-radius: 12rpx;
  border: 1rpx solid #ddd;
  background: #fff;
  color: #666;
}

.btn-small:active {
  background: #f0f0f0;
}

.btn-small[disabled] {
  opacity: 0.4;
}

.btn-undo {
  color: #e67e22;
  border-color: #e67e22;
}

.btn-new {
  color: #27ae60;
  border-color: #27ae60;
}

.btn-surrender {
  color: #e74c3c;
  border-color: #e74c3c;
}

/* 走法日志 */
.move-log {
  max-height: 200rpx;
  background: #fff;
  border-top: 1rpx solid #e0d5c0;
  padding: 16rpx 30rpx;
}

.log-title {
  font-size: 24rpx;
  color: #999;
}

.log-list {
  max-height: 150rpx;
}

.log-item {
  display: inline-block;
  margin-right: 20rpx;
  margin-top: 8rpx;
}

.log-num {
  color: #999;
  font-size: 22rpx;
}

.log-move {
  color: #333;
  font-size: 24rpx;
  margin-left: 4rpx;
}

/* 结果弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 560rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.3);
}

.result-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.result-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.result-reason {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.modal-card .btn {
  width: 100%;
}
