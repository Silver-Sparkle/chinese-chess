/* 历史记录 */
.page-header {
  margin-top: 30rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

/* 统计卡 */
.stats-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 30rpx 20rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #333;
}

.stat-num.win { color: #27ae60; }
.stat-num.lose { color: #e74c3c; }

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #eee;
}

/* 记录项 */
.record-item {
  margin: 12rpx 0 !important;
  padding: 24rpx 30rpx !important;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.type-badge {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.type-badge.ai {
  background: #e8f5e9;
  color: #27ae60;
}

.type-badge.multiplayer {
  background: #e3f2fd;
  color: #1976d2;
}

.record-date {
  font-size: 24rpx;
  color: #999;
}

.record-players {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin: 12rpx 0;
}

.player {
  font-size: 28rpx;
  font-weight: 500;
}

.player.red { color: #c0392b; }
.player.black { color: #2c3e50; }

.vs {
  font-size: 24rpx;
  color: #ccc;
}

.record-result {
  text-align: center;
  margin: 8rpx 0;
}

.result-text {
  font-size: 30rpx;
  font-weight: 700;
}

.result-text.win { color: #27ae60; }
.result-text.lose { color: #e74c3c; }
.result-text.draw { color: #f39c12; }

.result-reason {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

.record-meta {
  text-align: right;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 8rpx;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.empty-sub {
  display: block;
  font-size: 24rpx;
  margin-top: 8rpx;
}
