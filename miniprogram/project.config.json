{
  "description": "中国象棋 — 人机对战 & 联机对弈",
  "packOptions": {
    "ignore": [
      { "type": "folder", "value": "node_modules" },
      { "type": "file", "value": ".gitignore" }
    ],
    "include": []
  },
  "setting": {
    "es6": true,
    "postcss": true,
    "minified": true,
    "urlCheck": false,
    "coverView": true,
    "enhance": true,
    "lazyloadPlaceholderEnable": false,
    "minifyWXSS": true,
    "minifyWXML": true,
    "babelSetting": {
      "ignore": [],
      "disablePlugins": [],
      "outputPath": ""
    }
  },
  "compileType": "miniprogram",
  "libVersion": "3.5.0",
  "appid": "YOUR_APPID_HERE",
  "projectname": "chinese-chess",
  "condition": {},
  "editorSetting": {
    "tabIndent": "insertSpaces",
    "tabSize": 2
  }
}
